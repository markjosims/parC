{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ContingentFeatureMarkers",
  "description": "Schema for morphological realizations contingent on multiple features.",
  "type": "object",
  "required": ["kind", "features", "markers"],
  "additionalProperties": false,
  "properties": {
    "source_path": {
      "type": "string",
      "description": "The file path from which this config was loaded."
    },
    "kind": {
      "type": "string",
      "enum": ["ContingentFeatureMarkers"]
    },
    "features": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1,
      "description": "List of features involved in this contingent paradigm."
    },
    "global_order": {
      "type": "string",
      "description": "Allows specifying a default value for the 'order' attribute."
    },
    "global_marker": {
      "type": "array",
      "items": { "$ref": "#/definitions/marker" },
      "description": "A marker or list of markers applied to all forms in this paradigm."
    },
    "markers": {
      "type": "object",
      "description": "The root of the contingent hierarchy.",
      "$ref": "#/definitions/nestedNode"
    }
  },
  "definitions": {
    "marker": {
      "type": "object",
      "properties": {
        "type": { 
          "type": "string" ,
          "enum": ["prefix", "suffix", "infix", "replace", "suppletion", "rule"]
        },
        "value": { "oneOf": [
          { "type": "string" },
          { "type": "array", "items": { "type": "string" }, "minItems": 2, "maxItems": 2 }
          ]
        },
        "order": { "type": "string" },
        "comment": { "type": "string" }
      },
      "additionalProperties": false
    },
    "nestedNode": {
      "type": "object",
      "additionalProperties": {
        "oneOf": [
          { "type": "null" },
          { "$ref": "#/definitions/marker" },
          {
            "type": "array",
            "items": { "$ref": "#/definitions/marker" }
          },
          {
            "type": "object",
            "properties": {
              "inherits": { "type": "string", "pattern": "^\\$.*" }
            },
            "additionalProperties": { "$ref": "#/definitions/nestedNode" }
          },
          { "$ref": "#/definitions/nestedNode" }
        ]
      }
    }
  }
}