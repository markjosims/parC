{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Paradigm",
  "description": "Configuration defining an inflectional paradigm or sub-paradigm.",
  "type": "object",
  "required": ["kind", "part_of_speech", "markers"],
  "properties": {
    "source_path": {
      "type": "string",
      "description": "The file path from which this config was loaded."
    },
    "kind": {
      "type": "string",
      "enum": ["Paradigm"]
    },
    "part_of_speech": {
      "type": "string",
      "description": "The category of the root (e.g., verb, noun)."
    },
    "filter": {
      "type": "object",
      "description": "Logic to select specific lexical roots from the lexicon.",
      "properties": {
        "lexical_flag": { "type": "string" }
      },
      "additionalProperties": true
    },
    "order": {
      "type": "array",
      "items": { "type": "string" },
      "description": "The ordered stages of morphological application."
    },
    "global_markers": {
      "type": "array",
      "items": { "$ref": "./FeatureMarkers.json#/definitions/marker" },
      "description": "Markers or rules applied to every form in the paradigm."
    },
    "markers": {
      "type": "object",
      "description": "Mapping of features to their markers or import files.",
      "additionalProperties": {
        "oneOf": [
          { 
            "type": "string", 
            "description": "Literal value or file reference (starts with $)." 
          },
          { 
            "type": "object", 
            "description": "Inline markers mapping feature values to realizations.",
            "additionalProperties": { "$ref": "./FeatureMarkers.json#/definitions/marker" }
          }
        ]
      }
    },
    "feature_combinations": {
      "oneOf": [
        { "type": "string", "pattern": "^\\$.*" },
        { "type": "array", "items": { "type": "string", "pattern": "^\\$.*" } },
        { "$ref": "./FeatureCombinations.json#/definitions/combinations" }
      ],
      "description": "Imported or inline configuration(s) defining valid feature cross-products. If blank, all combinations of features are generated."
    },
    "contingent_features": {
      "type": "object",
      "description": "In-line contingent feature definitions.",
      "patternProperties": {
          "^[a-zA-Z][a-zA-Z0-9_]*&[a-zA-Z][a-zA-Z0-9_]$": {
            "oneOf": [
              { "type": "string", "pattern": "^\\$.*" },
              { 
                "additionalProperties": { "$ref": "./ContingentFeatureMarkers.json#/definitions/nestedNode" }
              }
            ]
          }
      }
    }
  },
  "definitions": {
    "marker": {
      "type": "object",
      "properties": {
        "suffix": { "type": "string" },
        "prefix": { "type": "string" },
        "replace": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 2,
          "maxItems": 2
        },
        "rule": { "type": "string", "pattern": "^\\$.*" },
        "suppletion": { "type": "string" },
        "order": { "type": "string" },
        "comment": { "type": "string" }
      },
      "additionalProperties": false
    }
  }
}