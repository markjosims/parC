{
    "name": "parC Demo",
    "image": "mcr.microsoft.com/devcontainers/python:3.10",
    "postCreateCommand": "curl -LsSf https://astral.sh/uv/install.sh | sh && uv sync && uvicorn src.api:app",
    "containerEnv": {
        "YAML_DIR": "./yaml"
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "redhat.vscode-yaml",
                "rioj7.vscode-file-template",
                "sleistner.vscode-fileutils"
            ]
        }
    },
    "forwardPorts": [8000]
}
